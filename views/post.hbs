<article class="page-section post-page">
  <div class="post-header">
    <div class="post-meta-row">
      <span class="post-meta-date">{{date}}</span>
      <span class="post-meta-author">{{author}}</span>
    </div>
    <h1 class="post-title-large">{{title}}</h1>
  </div>

  <div class="post-body">
    {{{content}}}
  </div>

  <div class="post-footer">
    <a href="/blog" class="back-link">← Back to Blog</a>
  </div>
</article>
